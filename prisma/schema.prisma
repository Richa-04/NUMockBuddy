generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ResumeScan {
  id            String   @id @default(cuid())
  userId        String
  score         Int
  scanType      ScanType
  issuesFound   Json
  resumeSnippet String
  improvements  Json?
  createdAt     DateTime @default(now())
  fileName      String?
}

model ChatSession {
  id        String        @id @default(cuid())
  userId    String
  title     String
  createdAt DateTime      @default(now())
  messages  ChatMessage[]
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  role      MessageRole
  content   String
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id])
}

model Volunteer {
  id                String             @id @default(cuid())
  name              String
  email             String?
  degree            String?
  company           String?
  role              String?
  bio               String?
  skills            String?
  availability      String             @default("available")
  createdAt         DateTime           @default(now())
  sessions          Session[]
  availabilitySlots AvailabilitySlot[]
}

model AvailabilitySlot {
  id          String    @id @default(cuid())
  volunteerId String
  volunteer   Volunteer @relation(fields: [volunteerId], references: [id])
  day         String
  startTime   String
  endTime     String
  booked      Boolean   @default(false)
}

model Session {
  id          String    @id @default(cuid())
  volunteerId String
  volunteer   Volunteer @relation(fields: [volunteerId], references: [id])
  requester   String
  slotId      String?
  status      String    @default("pending")
  notes       String?
  createdAt   DateTime  @default(now())
}

enum ScanType {
  JD_MATCH
  ROLE_RATE
  ATS
}

enum MessageRole {
  USER
  ASSISTANT
}

model User {
  id           String   @id @default(cuid())
  nuid         String   @unique
  fullName     String
  email        String   @unique
  program      String?
  gradYear     String?
  passwordHash String
  createdAt    DateTime @default(now())
}

model PracticeSession {
  id            String   @id @default(cuid())
  userId        String?
  company       String
  role          String
  interviewType String
  jobType       String
  overallScore  Int
  verdict       String
  answeredCount Int      @default(0)
  skippedCount  Int      @default(0)
  totalFillers  Int      @default(0)
  totalRepeated Int      @default(0)
  eyeContact    Float?
  confidence    Float?
  engagement    Float?
  createdAt     DateTime @default(now())
}

model Feedback {
  id        String   @id @default(cuid())
  type      String
  rating    Int?
  text      String
  extra     Json?
  createdAt DateTime @default(now())
}
